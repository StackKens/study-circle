# Production — Netlify proxies REST via /api/*, but sockets must go directly to Railway
VITE_API_URL=/api
VITE_SOCKET_URL=your_url
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_CLOUDINARY_CLOUD_NAME=your_cloudname
VITE_CLOUDINARY_UPLOAD_PRESET=your upload-reset
