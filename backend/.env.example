PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/studycircle
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRES_IN=7d
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# AI (OpenAI or Groq — Groq keys start with gsk_)
