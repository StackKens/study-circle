# Email — choose one: SendGrid OR SMTP
SENDGRID_API_KEY=
FROM_EMAIL=no-reply@studycircle.app

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
